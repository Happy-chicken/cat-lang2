class Vec {
  let x: int = 0;
  let y: int = 0;
}

class Tuple {
  let a: int = 0;
  let b:int = 0;
}

trait Printable {
  decl say(self:Vec) -> char;
}

impl Printable for Vec {
  def say(self:Vec) -> char {
    return 'a';
  }
}

impl Printable for Tuple {
  def say(self:Tuple) -> char {
    return 'b';
  }
}

impl Vec {
  def add_one(self:Vec) {
    self.x = self.x + 1;
    self.y = self.y + 1;
  }
}

def main() ->int {
  let a = Vec(1, 2);
  a.add_one();
  let c = a.say();
  let b = Vec(3, 4);
  return a.x + a.y + b.x + b.y;
}