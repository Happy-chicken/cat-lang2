# 基于 LLVM 风格
BasedOnStyle: LLVM

# 缩进宽度（LLVM 默认 2，可自定义）
IndentWidth: 2
UseTab: Never

# 列宽限制（LLVM 默认 80）
ColumnLimit: 120

# 大括号风格（LLVM 默认 Attach）
BreakBeforeBraces: Attach

# 函数单行显示（LLVM 默认 Inline）
AllowShortFunctionsOnASingleLine: Inline

# 指针/引用对齐（LLVM 默认 Left）
PointerAlignment: Left

# 访问修饰符缩进（LLVM 默认 -1）
AccessModifierOffset: -2

# 命名空间缩进（LLVM 默认 None）
NamespaceIndentation: None

# 每行注释前空格（LLVM 默认 1）
SpacesBeforeTrailingComments: 1

# 是否在空函数体保留换行
AllowShortFunctionsOnASingleLine: Inline
